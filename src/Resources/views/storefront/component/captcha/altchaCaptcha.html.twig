{% block component_captcha_altcha %}
    {% set configPath = constant('Frosh\\AltchaCaptcha\\Storefront\\Framework\\AltchaCaptcha::CONFIG_PATH') %}

    {% if not config(configPath ~ '.whitelistCustomers') %}
        {% set autoMode = config(configPath ~ '.autoMode') %}

        {% set configuration = {} %}
        {% if config(configPath ~ '.hideFooter') %}
            {% set configuration = configuration|merge({ hideFooter: true }) %}
        {% endif %}
        {% if config(configPath ~ '.hideLogo') %}
            {% set configuration = configuration|merge({ hideLogo: true }) %}
        {% endif %}

        <altcha-widget
            challenge="{{ path('widgets.altcha.challenge') }}"
            configuration="{{ configuration|json_encode }}"
            {% if config(configPath ~ '.floating') %}
                display="floating"
            {% endif %}
            {% if config(configPath ~ '.invisible') %}
                {% set autoMode = 'onsubmit' %}
                class="d-none"
            {% endif %}

            auto="{{ autoMode }}"
        ></altcha-widget>
    {% endif %}
{% endblock %}
